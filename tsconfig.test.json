{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-build",
    "rootDir": ".",
    "tsBuildInfoFile": ".test-build/tsconfig.test.tsbuildinfo",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/domain/**/*.ts",
    "src/repositories/**/*.ts",
    "src/services/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", ".test-build"]
}
